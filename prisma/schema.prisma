generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  githubId   String?
  leetcodeId String?
  codechefId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
